<Layouts.flash_group flash={@flash} />

<section class="sw-login-wrap">
  <div class="sw-login-card">
    <p class="sw-brand-kicker">SentientWave Automata</p>
    <h1 class="sw-login-title">Admin Login</h1>
    <p class="sw-login-copy">
      Secure access to onboarding, LLM configuration, and tool administration.
    </p>

    <form action={~p"/login"} method="post" class="sw-login-form">
      <input type="hidden" name="_csrf_token" value={Plug.CSRFProtection.get_csrf_token()} />

      <label class="sw-field">
        <span>Admin Username</span>
        <input name="username" value={@default_user} class="sw-input" autocomplete="username" />
      </label>

      <label class="sw-field">
        <span>Admin Password</span>
        <input
          name="password"
          type="password"
          class="sw-input"
          autocomplete="current-password"
        />
      </label>

      <button type="submit" class="sw-btn sw-btn-primary sw-btn-block">Sign In</button>
    </form>

    <%= unless @password_configured? do %>
      <div class="sw-alert sw-alert-warning">
        Set <code>AUTOMATA_WEB_ADMIN_PASSWORD</code>
        (or <code>MATRIX_ADMIN_PASSWORD</code>) before production use.
      </div>
    <% end %>

    <%= if @insecure_default? do %>
      <div class="sw-alert sw-alert-danger">
        Current admin password is insecure (blank or default). Rotate immediately.
      </div>
    <% end %>
  </div>
</section>
